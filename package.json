{
  "name": "glimpseui",
  "version": "0.3.7",
  "description": "Native micro-UI for scripts and agents with platform-specific hosts",
  "type": "module",
  "main": "src/glimpse.mjs",
  "exports": {
    ".": "./src/glimpse.mjs"
  },
  "bin": {
    "glimpseui": "bin/glimpse.mjs"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:macos": "node scripts/build.mjs darwin",
    "build:windows": "node scripts/build.mjs win32",
    "postinstall": "node scripts/postinstall.mjs",
    "test": "node test/test.mjs",
    "test:platform": "node test/platform.mjs",
    "demo:windows": "node scripts/demo-windows.mjs",
    "demo:companion": "node scripts/demo-companion.mjs",
    "demo:html": "node scripts/demo-html-interaction.mjs",
    "publish:check": "./scripts/publish.sh --dry-run",
    "publish:npm": "./scripts/publish.sh"
  },
  "files": [
    "src/glimpse.swift",
    "src/glimpse.mjs",
    "bin/glimpse.mjs",
    "NuGet.config",
    "native/windows/Glimpse.Windows.csproj",
    "native/windows/Program.cs",
    "scripts/build.mjs",
    "scripts/postinstall.mjs",
    "scripts/demo-windows.mjs",
    "scripts/demo-companion.mjs",
    "scripts/demo-html-interaction.mjs",
    "scripts/demo/",
    "pi-extension/index.ts",
    "pi-extension/companion.mjs",
    "pi-extension/socket-path.mjs",
    "skills/glimpse/SKILL.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": [
      "./pi-extension/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "win32"
  ],
  "keywords": [
    "macos",
    "windows",
    "webview",
    "native",
    "ui",
    "webkit",
    "wkwebview",
    "webview2",
    "swift",
    "gui",
    "agent",
    "dialog",
    "prompt",
    "overlay",
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hazat/glimpse"
  },
  "author": "hazat",
  "license": "MIT"
}
